{
  "name": "Nout",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "npm run test:firebase",
    "test:firebase": "firebase emulators:exec --project demo-nout --only auth,firestore \"vitest run --config vitest.firebase.config.ts\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "preview": "vite preview",
    "prepare": "husky install"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.1.1",
    "@mui/material": "^7.1.1",
    "@tiptap/extension-code-block-lowlight": "^3.11.1",
    "@tiptap/extension-highlight": "^3.10.1",
    "@tiptap/extension-typography": "^3.10.1",
    "@tiptap/react": "^3.10.1",
    "@tiptap/starter-kit": "^3.10.1",
    "firebase": "^12.12.0",
    "lowlight": "^3.3.0",
    "material-ui-popup-state": "^5.3.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^3.9.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^6.1.1",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-storybook": "^9.0.8",
    "firebase-tools": "^15.14.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "^3.5.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "@opentelemetry/core": "^2.8.0",
    "gaxios": {
      "uuid": "^11.1.1"
    }
  },
  "lint-staged": {
    "*.{js,ts,tsx}": "eslint --cache --fix",
    "*.{js,ts,tsx,css,md}": "prettier --write"
  }
}
